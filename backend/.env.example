# Backend environment variables
# Copy this file to .env (same folder) and fill in values.

# Required for production CORS; optional for local dev
# FRONTEND_ORIGIN=http://localhost:8080

# Admin credentials for HTTP Basic Auth
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Optional: store a bcrypt hash instead of ADMIN_PASSWORD
# If set, ADMIN_PASSWORD is ignored.
# ADMIN_PASSWORD_HASH=

# Other existing env vars (keep what you already use)
# DATABASE_URL=
# NODE_ENV=development
# PORT=3000
