# Backend environment variables
#
# SETUP:
#   1. Copy this file to a new file named ".env" in this same "backend" folder.
#   2. Fill in the values below.
#   3. Restart the server (npm start / node server.js).
#
# The server will REFUSE TO START and print a readable error if
# ADMIN_USERNAME or ADMIN_PASSWORD (or ADMIN_PASSWORD_HASH) are missing.

# Required for production CORS; optional for local dev
# FRONTEND_ORIGIN=http://localhost:8080

# ---- Admin login (REQUIRED) ----
# Used by POST /api/login and by HTTP Basic Auth on protected /api/admin/* routes.
# ADMIN_USERNAME is required.
ADMIN_USERNAME=myadmin@gmail.com

# Provide EITHER ADMIN_PASSWORD (plain text, simplest for local dev)
# OR ADMIN_PASSWORD_HASH (bcrypt hash, recommended for production).
# If ADMIN_PASSWORD_HASH is set, ADMIN_PASSWORD is ignored.
ADMIN_PASSWORD=mysecurepassword123

# Optional: bcrypt hash instead of ADMIN_PASSWORD.
# Generate one with: node -e "console.log(require('bcrypt').hashSync('yourPassword', 10))"
# ADMIN_PASSWORD_HASH=

# Other existing env vars (keep what you already use)
# DATABASE_URL=
# NODE_ENV=development
# PORT=3000
