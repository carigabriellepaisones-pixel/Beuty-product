// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  Pending
  Shipped
}

enum ProductType {
  SINGLE
  BUNDLE
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String?
  phone        String?
  address      String?
  passwordHash String
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())

  orders Order[]
}

model Product {
  id                Int         @id @default(autoincrement())
  name              String
  price             Decimal     @db.Decimal(10, 2)
  stock             Int         @default(0)
  imageUrl          String?     @map("image_url")
  description       String?     @map("description")
  usageInstructions String?     @map("usage_instructions")
  type              ProductType @default(SINGLE)
  includes          String?     @map("includes")
  storefrontLayer   Int         @default(1) @map("storefront_layer")
  isActive          Boolean     @default(true)
  createdAt         DateTime    @default(now())

  orderItems OrderItem[]
}

model Order {
  id        Int         @id @default(autoincrement())
  status    OrderStatus @default(Pending)
  createdAt DateTime    @default(now())

  customerName String?
  phone        String?
  address      String?

  subtotal    Decimal? @db.Decimal(10, 2)
  shippingFee Decimal? @map("shipping_fee") @db.Decimal(10, 2)
  total       Decimal? @db.Decimal(10, 2)

  paymentStatus String? @map("payment_status")
  orderStatus   String? @map("order_status")

  courierName    String? @map("courier_name")
  trackingNumber String? @map("tracking_number")
  paymentMethod  String  @default("Cash on Delivery") @map("payment_method")

  receiptRef         String? @map("receipt_ref") @db.VarChar(50)
  customerReceiptUrl String? @map("customer_receipt_url") @db.VarChar(255)

  userId Int?
  user   User? @relation(fields: [userId], references: [id])

  items OrderItem[]

  @@map("order")
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  orderId   Int @map("order_id")
  productId Int? @map("product_id")

  productName String
  variant     String?
  quantity    Int
  unitPrice   Decimal @map("unit_price") @db.Decimal(10, 2)

  order   Order    @relation(fields: [orderId], references: [id])
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([orderId])
  @@index([productId])
  @@map("orderitem")
}
